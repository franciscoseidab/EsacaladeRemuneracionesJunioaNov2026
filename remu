    function toggleTheme() {
        const currentTheme = document.documentElement.getAttribute('data-theme');
        let targetTheme = 'light';
        let btnHTML = '<span>🌙</span> Modo Noche';
        
        if (currentTheme !== 'dark') {
            targetTheme = 'dark';
            btnHTML = '<span>☀️</span> Modo Día';
        }
        
        document.documentElement.setAttribute('data-theme', targetTheme);
        document.getElementById('theme-toggle').innerHTML = btnHTML;
    }

    function init() {
        const selectGrado = document.getElementById('select-grado');
        const sortedGrades = Object.keys(remuneracionesData).sort((a,b) => parseInt(a) - parseInt(b));
        
        sortedGrades.forEach(grado => {
            const opt = document.createElement('option');
            opt.value = grado;
            opt.textContent = `Grado ${grado} - ${remuneracionesData[grado].estamento}`;
            if(grado == "11") opt.selected = true;
            selectGrado.appendChild(opt);
        });
        
        updateCalculator();
    }

    function formatCurrency(value) {
        return new Intl.NumberFormat('es-CL', { style: 'currency', currency: 'CLP', minimumFractionDigits: 0, maximumFractionDigits: 0 }).format(value);
    }

    function switchTab(tabId) {
        document.querySelectorAll('.tab-content').forEach(el => el.classList.remove('active'));
        document.querySelectorAll('.tab-btn').forEach(el => el.classList.remove('active'));
        
        document.getElementById(tabId).classList.add('active');
        event.currentTarget.classList.add('active');
    }

    function updateCalculator() {
        const grado = document.getElementById('select-grado').value;
        const data = remuneracionesData[grado];
        
        if (!data) return;

        document.getElementById('input-estamento').value = data.estamento;
        document.getElementById('valor-diurna-label').textContent = `Valor Hora Diurna (25%): ${formatCurrency(data.hora_diurna)}`;
        document.getElementById('valor-nocturna-label').textContent = `Valor Hora Nocturna/Festiva (50%): ${formatCurrency(data.hora_nocturna)}`;

        const hDiurnas = parseFloat(document.getElementById('input-horas-diurnas').value) || 0;
        const hNocturnas = parseFloat(document.getElementById('input-horas-nocturnas').value) || 0;
        const useAsigProf = document.getElementById('check-asig-prof').checked;
        const useAsigDir = document.getElementById('check-asig-dir').checked;

        const montoHorasExtras = (hDiurnas * data.hora_diurna) + (hNocturnas * data.hora_nocturna);

        document.getElementById('td-sueldo-base').textContent = formatCurrency(data.sueldo_base);
        document.getElementById('td-incremento').textContent = formatCurrency(data.incremento);
        document.getElementById('td-asig-mun').textContent = formatCurrency(data.asig_mun);
        document.getElementById('td-ley-18717').textContent = formatCurrency(data.ley_18717);
        document.getElementById('td-ley-18566').textContent = formatCurrency(data.ley_18566);
        document.getElementById('td-ley-18675').textContent = formatCurrency(data.ley_18675);
        document.getElementById('td-asig-zona').textContent = formatCurrency(data.asig_zona);
        document.getElementById('td-asig-19529').textContent = formatCurrency(data.asig_19529);
        document.getElementById('td-ley-20033').textContent = formatCurrency(data.ley_20033);

        let extraAsigMonto = 0;
        if (useAsigProf && data.asig_prof_20922 > 0) {
            document.getElementById('row-asig-prof').style.display = 'table-row';
            document.getElementById('td-asig-prof').textContent = formatCurrency(data.asig_prof_20922);
            extraAsigMonto += data.asig_prof_20922;
        } else {
            document.getElementById('row-asig-prof').style.display = 'none';
        }

        if (useAsigDir && data.asig_dir_20922 > 0) {
            document.getElementById('row-asig-dir').style.display = 'table-row';
            document.getElementById('td-asig-dir').textContent = formatCurrency(data.asig_dir_20922);
            extraAsigMonto += data.asig_dir_20922;
        } else {
            document.getElementById('row-asig-dir').style.display = 'none';
        }

        document.getElementById('td-horas-extras-monto').textContent = formatCurrency(montoHorasExtras);

        const totalHaberConsolidado = data.total_haber + extraAsigMonto + montoHorasExtras;
        const liquidoEstimado = totalHaberConsolidado * 0.8;

        document.getElementById('kpi-total-haber').textContent = formatCurrency(data.total_haber + extraAsigMonto);
        document.getElementById('kpi-horas-extras').textContent = formatCurrency(montoHorasExtras);
        document.getElementById('kpi-pmg').textContent = formatCurrency(data.pmg_trimes);
        document.getElementById('kpi-liquido').textContent = formatCurrency(liquidoEstimado);

        document.getElementById('td-total-haber-final').textContent = formatCurrency(totalHaberConsolidado);
        document.getElementById('td-liquido-final').textContent = formatCurrency(liquidoEstimado);

        document.getElementById('td-pmg-base-calculo').textContent = formatCurrency(data.base_pmg);
        document.getElementById('td-pmg-comp-base').textContent = formatCurrency(data.comp_base_15);
        document.getElementById('td-pmg-inst').textContent = formatCurrency(data.inst_76);
        document.getElementById('td-pmg-colectivo').textContent = formatCurrency(data.colect_8);
        document.getElementById('td-pmg-trimestral-total').textContent = formatCurrency(data.pmg_trimes);
    }

    window.onload = init;
</script>
